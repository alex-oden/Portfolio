# ── Aloden access gate (Plan B) ────────────────────────────────
# NOTE: we do NOT use a site-wide "Require valid-user" here. On this
# LiteSpeed server, a blanket rule + <FilesMatch> "Require all granted"
# exceptions does not work — the blanket wins and locks the landing page
# too. So instead we leave everything PUBLIC by default and put the
# password ONLY on the real portfolio pages below.
#
# The .htpasswd is created by cPanel → Directory Privacy and lives OUTSIDE
# the web root, so the rsync --delete deploy never touches it. This file is
# committed to git, so deploys preserve it (and overwrite cPanel's auto one).

AuthType Basic
AuthName "Aloden — enter password to continue"
# Path confirmed from the cPanel-generated .htaccess (Directory Privacy).
AuthUserFile "/home/alexoden/.htpasswds/staging.alexoden.com/passwd"

# "/" serves the public coming-soon landing.
DirectoryIndex coming-soon.html index.html

# Password-protect ONLY the portfolio pages. Everything else — the
# coming-soon landing, /assets/, the résumé PDF — stays public.
# If you add a new private page, add its filename to this list.
<FilesMatch "^(index|blog|blog-single|resume|work|work-single)\.html$">
  Require valid-user
</FilesMatch>

# Keep the staging site out of search engines while it is gated.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
