# ── Aloden access gate (Plan B) ────────────────────────────────
# Everything is password-protected by default. The exceptions below keep
# the public landing page working: the coming-soon page itself, the
# downloadable résumé, and all static assets (css/js/img/fonts) so the
# page renders for visitors who are NOT logged in.
#
# The .htpasswd is created by cPanel → Directory Privacy and lives OUTSIDE
# the web root, so the rsync --delete deploy never touches it. This file is
# committed to git, so deploys preserve it (and overwrite cPanel's auto one).

AuthType Basic
AuthName "Aloden — enter password to continue"
# Path confirmed from the cPanel-generated .htaccess (Directory Privacy).
AuthUserFile "/home/alexoden/.htpasswds/staging.alexoden.com/passwd"

# Protect the whole site by default.
Require valid-user

# Public visitors land on the coming-soon page (no password).
DirectoryIndex coming-soon.html index.html

# Public page(s): the landing screen + the downloadable résumé.
<FilesMatch "^(coming-soon\.html|AlexOden_Resume_ENG_Dark\.pdf)$">
  Require all granted
</FilesMatch>

# Public static assets — matched by extension, anywhere in the site — so the
# landing page renders with its CSS, fonts, JS and logo for logged-out users.
<FilesMatch "\.(css|js|mjs|map|svg|png|jpe?g|gif|webp|avif|ico|woff2?|ttf|otf|eot)$">
  Require all granted
</FilesMatch>

# Keep the staging site out of search engines while it is gated.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
