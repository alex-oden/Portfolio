# ── Aloden access gate (Plan B) ────────────────────────────────
# Public landing page ("/" → coming-soon.html) is open to everyone.
# The real portfolio (index.html, work.html, …) requires the password.
#
# The .htpasswd is created by cPanel → Directory Privacy and lives OUTSIDE
# the web root, so the rsync --delete deploy never touches it. This file is
# committed to git, so deploys preserve it (and overwrite cPanel's auto one).

AuthType Basic
AuthName "Aloden — enter password to continue"
# Path confirmed from the cPanel-generated .htaccess (Directory Privacy).
AuthUserFile "/home/alexoden/.htpasswds/staging.alexoden.com/passwd"

# Public visitors land on the coming-soon page without a password.
DirectoryIndex coming-soon.html index.html

# Mark which URLs are public. SetEnvIf is evaluated against the REQUESTED
# url, so the bare "/" request (which DirectoryIndex resolves to
# coming-soon.html) is matched here — that's why the FilesMatch approach
# failed and this one works.
SetEnvIf Request_URI "^/(coming-soon\.html)?$"           aloden_public
SetEnvIf Request_URI "^/AlexOden_Resume_ENG_Dark\.pdf$"  aloden_public
SetEnvIf Request_URI "^/assets/"                         aloden_public

# Public URLs pass; everything else needs a valid login.
<RequireAny>
  Require env aloden_public
  Require valid-user
</RequireAny>

# Keep the staging site out of search engines while it is gated.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
